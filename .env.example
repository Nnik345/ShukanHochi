# Cognito (Amplify / Vite build)
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_AUTHORITY=
VITE_COGNITO_DOMAIN=
VITE_COGNITO_LOGOUT_URI=

# Profile (Mongo user) — either full URLs or same gateway + Lambda names (HTTP API $default routes)
VITE_API_FETCH_URL=
VITE_API_UPDATE_URL=
# If you use one HTTP API with stage path /default, set base once and the Lambda route names:
# VITE_API_GATEWAY_URL=https://37qn47z124.execute-api.ap-south-1.amazonaws.com/default
# VITE_API_LAMBDA_FETCH=yourProfileGetFunctionName
# VITE_API_LAMBDA_UPDATE=yourProfilePostFunctionName

# Party + profile composition: base must include stage (e.g. .../default). Paths are Lambda names:
# searchUser, partyInvite, partyInvitesIncoming, partyInviteAccept, partyInviteDecline,
# partyListMine, partyLeave, partyDissolve
VITE_API_GATEWAY_URL=

# Optional: dev server proxy target only (overrides VITE_API_GATEWAY_URL for vite.config.js /api/aws)
# VITE_DEV_PROXY_TARGET=

# Optional: override individual party URLs (full URL each; if all set, VITE_API_GATEWAY_URL paths are ignored)
# VITE_API_PARTY_SEARCH_URL=
# VITE_API_PARTY_INVITE_URL=
# VITE_API_PARTY_INVITES_INCOMING_URL=
# VITE_API_PARTY_ACCEPT_URL=
# VITE_API_PARTY_DECLINE_URL=
# VITE_API_PARTY_PARTIES_ME_URL=
# VITE_API_PARTY_LEAVE_URL=
# VITE_API_PARTY_DISSOLVE_URL=
